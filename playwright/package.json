{
  "name": "full-stack-qa-playwright",
  "version": "1.0.0",
  "description": "Playwright tests for full-stack-qa framework",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:chrome": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:integration": "playwright test --config=playwright.integration.config.ts",
    "test:integration:ui": "playwright test --config=playwright.integration.config.ts --ui",
    "test:integration:headed": "playwright test --config=playwright.integration.config.ts --headed",
    "load:test": "artillery run",
    "load:test:all": "artillery run artillery/scenarios/*.yml",
    "load:test:homepage": "artillery run artillery/scenarios/homepage-load.yml",
    "load:test:applications": "artillery run artillery/scenarios/applications-flow.yml"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3",
    "artillery": "^2.0.30"
  },
  "overrides": {
    "lodash": ">=4.17.23",
    "fast-xml-parser": ">=5.3.4",
    "minimatch": "9.0.7",
    "glob": { "minimatch": "3.1.4" },
    "filelist": { "minimatch": "5.1.8" },
    "matcher-collection": { "minimatch": "3.1.4" }
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}

