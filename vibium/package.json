{
  "name": "full-stack-qa-vibium",
  "version": "1.0.0",
  "description": "Vibium tests for full-stack-qa framework",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "test:ui": "npx vitest --ui",
    "vibe": "tsx helpers/example.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist coverage test-results .vitest"
  },
  "dependencies": {
    "vibium": "^26.5.31"
  },
  "optionalDependencies": {
    "@vibium/darwin-arm64": "^26.3.18",
    "@vibium/linux-x64": "^26.3.18"
  },
  "devDependencies": {
    "@types/node": "^25.9.5",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
